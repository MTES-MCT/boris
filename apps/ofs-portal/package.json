{
  "name": "@boris/ofs-portal",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.19.0",
    "npm": "10.8.2"
  },
  "scripts": {
    "start:dev": "vite dev",
    "build": "svelte-kit sync && vite build",
    "start": "node build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "generate-api-types": "openapi-typescript http://localhost:3000/api/documentation/schema/json --output src/lib/types/generated-api-types.ts"
  },
  "devDependencies": {
    "@gouvfr/dsfr": "^1.14.2",
    "@playwright/test": "^1.28.1",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.17.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0-next.6",
    "eslint-plugin-svelte": "^2.36.0",
    "openapi-typescript": "^7.8.0",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte": "^5.16.6",
    "svelte-check": "^4.0.0",
    "vite": "^5.0.3",
    "vitest": "^2.0.0"
  },
  "type": "module"
}
